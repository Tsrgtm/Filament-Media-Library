{
    "name": "tsrgtm/filament-media-library",
    "description": "A production-ready, highly extensible Filament-native media library plugin for Laravel.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Tusar Gautam",
            "email": "gautamtusar2@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/queue": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
        "intervention/image": "^3.0",
        "filament/filament": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Tsrgtm\\FilamentMediaLibrary\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tsrgtm\\FilamentMediaLibrary\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tsrgtm\\FilamentMediaLibrary\\MediaLibraryServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}